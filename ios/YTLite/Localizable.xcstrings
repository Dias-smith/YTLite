    "settings.sleep_footer_active": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتوقف التشغيل تلقائيًا عند انتهاء المؤقت. تبقى قائمة الانتظار والمشغّل المصغّر."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Playback pauses automatically when the timer ends. Queue and mini player stay."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La reproducción se pausa automáticamente al acabar el temporizador. La cola y el minirreproductor se mantienen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La lecture se met en pause automatiquement à la fin du minuteur. La file et le mini-lecteur restent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टाइमर खत्म होने पर प्लेबैक अपने आप रुक जाता है। कतार और मिनी प्लेयर बने रहते हैं।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A reprodução pausa automaticamente quando o temporizador acaba. A fila e o mini player permanecem."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "定时结束后会自动暂停播放。队列和迷你播放器会保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "定時結束後會自動暫停播放。佇列與迷你播放器會保留。"
          }
        }
      }
    },
