    "you.apple_needs_google_desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscriptions and Liked videos come from your YouTube account. Sign in with Google to load this tab. Your Apple-signed-in library stays separate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "订阅与赞过的视频来自你的 YouTube 账号。请使用 Google 登录以加载此页。通过 Apple 登录的媒体库账号相互独立。"
          }
        }
      }
    },
