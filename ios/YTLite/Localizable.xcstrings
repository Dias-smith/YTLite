    "you.access_desc": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدّل الحساب أو سجّل الدخول مجددًا لمنح وصول YouTube للقراءة فقط للاشتراكات."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switch account or sign in again to grant YouTube readonly access for subscriptions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia de cuenta o inicia sesión de nuevo para conceder acceso de solo lectura de YouTube a las suscripciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Changez de compte ou reconnectez-vous pour accorder l'accès YouTube en lecture seule aux abonnements."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सब्सक्रिप्शन के लिए YouTube रीडओनली ऐक्सेस देने हेतु खाता बदलें या फिर से साइन इन करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Troque de conta ou entre novamente para conceder acesso somente leitura do YouTube às inscrições."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请切换账号或重新登录，以授予订阅所需的 YouTube 只读权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請切換帳號或重新登入，以授予訂閱所需的 YouTube 唯讀權限。"
          }
        }
      }
    },
